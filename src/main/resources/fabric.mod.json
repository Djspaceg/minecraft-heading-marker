{
  "schemaVersion": 1,
  "id": "headingmarker",
  "version": "${version}",
  "name": "Heading Marker",
  "description": "Waypoint management mod. Works server-side OR client-side (singleplayer). Optional on clients when connecting to servers with the mod installed.",
  "authors": [
    "Djspaceg"
  ],
  "contact": {
    "homepage": "https://www.daolan.com/",
    "sources": "https://github.com/Djspaceg/minecraft-heading-marker"
  },
  "license": "CC0-1.0",
  "icon": "assets/headingmarker/icon.png",
  "environment": "*",
  "custom": {
    "modmenu": {
      "badges": [
        "library"
      ]
    }
  },
  "entrypoints": {
    "main": [
      {
        "adapter": "kotlin",
        "value": "com.daolan.headingmarker.HeadingMarkerMod"
      }
    ],
    "client": [
      {
        "adapter": "kotlin",
        "value": "com.daolan.headingmarker.HeadingMarkerClientMod"
      }
    ]
  },
  "depends": {
    "fabricloader": ">=0.18.5",
    "minecraft": "26.1",
    "java": ">=25",
    "fabric-api": "*",
    "fabric-language-kotlin": "*"
  },
  "suggests": {}
}